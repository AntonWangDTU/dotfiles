{
    "layer": "top",
    "position": "top",
    "height": 14,
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "bluetooth",
        "custom/pixel",
        "custom/pipewire",
        "network",
        "battery",
        "sway/language",
        "clock",
        "tray"
    ],
    "sway/window": {
        "max-length": 35
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1:web": "",
            "2:code": "",
            "3:term": "",
            "4:work": "",
            "5:music": "",
            "6:docs": "",
            "urgent": ""
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "spacing": 8
    },
    "clock": {
        "format": "{:%d-%m-%Y %H:%M}",
        "format-alt": "{:%d-%m-%Y}",
        "timezone": "Europe/Copenhagen"
    }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{capacity}%  ",
        "format-plugged": "{capacity}%  ",
        "format-alt": "{time} {icon}",
        "format-icons": [
            " ",
            " ",
            " ",
            " ",
            " "
        ]
    },
    "network": {
        "format-wifi": "  {essid} ({signalStrength}%)",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr}  ",
        "format-disconnected": "Disconnected ⚠ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "sway/language": {
        "format": "{short}"
    },
    "bluetooth": {
        "format": "{icon}",
        "format-alt": "bluetooth: {status}",
        "format-icons": {
            "enabled": " ",
            "disabled": ""
        },
        "tooltip-format": "{}",
        "on-click": "blueman-manager"
    },
    "custom/pixel": {
        "format": "G {} ",
        "exec": "bash $HOME/dotfiles/scripts/misc/pixelbuds.sh 2> /dev/null",
        "exec-if": "bash ~/scripts/misc/pixelbuds_con.sh",
        "interval": 60,
        "tooltip-format": "Google Pixel Buds: Battery {}"
    },
    "custom/pipewire": {
        "format": "{}",
        "signal": 8,
        "interval": "once",
        "exec": "bash ~/scripts/misc/audio.sh"
    },
    "cpu": {
        "format": "{usage}%  ",
        "on-click": "alacritty -e btop"
    },
    "memory": {
        "format": "{}%  "
    },
}
